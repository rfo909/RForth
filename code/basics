(ops with fixed byte codes)

: constant (value -- )
	create                             (makes a constant with value 0 - dont need to set DE->type)
	(value) *dictHead 3 + !            (3+ = DE->address)
;

2 constant OP_BVAL
3 constant OP_CVAL
4 constant OP_RET
5 constant OP_JMP
6 constant OP_COND_JMP
7 constant OP_BLOB

0 constant DE_NORMAL
1 constant DE_IMMEDIATE
2 constant DE_CONSTANT

2 constant cell

: 1+ 1 + ;
: cells cell * ;

: over 1 pick ;
: 2dup over over ;

: RDup 0 rpick ;
: RPeek RDup R> ;
: RSwap R> R> swap >R >R ;
: RDrop R> drop ;


(dictionary entry field offsets)

: DE->name (dePtr -- fieldPtr) ;
: DE->type (dePtr -- fieldPtr) 2 + ;	(1 byte)
: DE->address (dePtr -- fieldPtr) 3 + ;
: DE->next (dePtr -- fieldPtr) 5 + ;

: variable (--)
	HERE cell allot constant
;


: immediate
	DE_IMMEDIATE *dictHead DE->type c!
;

(Ex. 145 123 kL  --- results in 145123 as Long value on xStack)
: kL (kval val -- Lval)
	swap >L 1000 >L L* 
	>L L+
;

: cr 0x0A emit ;

: , HERE cell allot ! ;

: c, HERE 1 allot ! ;

48 constant CH_ZERO
49 constant CH_ONE


: .bit (bool --)
	&1 jmp?  
	CH_ZERO emit ret
	/1 CH_ONE emit
;

: .bits (byte --)
	0x80    (byte bit)
	/0
		dup 0 == &1 jmp?    (exit)
		dup (byte bit bit)
		2 pick & .bit (byte bit)
		1 >>
		&0 jmp
	/1
		drop drop
;



