(should really be a system flag, set by the colon compiler)

: IsCompiling
	*Dict @ DE->address @ 0 ==
;


(custom dictionary start)

: CDict
	create
	*Dict @ >R RSwap
		(store current dictionary pointer - includes the newly created word)
; 

(custom dictionary end)

: CDictEnd
	RSwap
	
	(set address of the new Dict entry)
	*Dict @ 
		RDup R> DE->address !
	
	(change global dictionary to point to omit content added since Dict)
	R> *Dict !
;

(lookup nextWord in a dictionary)

: DictLookupNW (dictPointer -- word-address) 
	/0
		dup 0 == &1 jmp?  (end of dictionary linked list)
		dup DE->name @ nextWordEq &2 jmp?  (found it)
		
		DE->next @                       (follow next pointer)
		&0 jmp
	/1
		cr s" not found" .str
		drop
		0 ret
	/2
		DE->address @
; 

(
For testing, use dcall to call returned address
)

: DictLookup (dictPointer [name])
	readNextWord DictLookupNW
;
	
: => ([dict] [name] -- ...) (compile call to word inside dictionary)
	readNextWord *Dict @ DictLookupNW  (dictionary reference)
	readNextWord DictLookupNW (word in dictionary reference)
	
	dup 0 == &1 jmp?         (not found)

	(generate call syntax)
	dup 8 >> 0xFF & 0x80 | comp.out
	0xFF & comp.out
	ret	
	
	/1
	s" Dictionary word not found" .str
	OP_RET comp.out
	drop
	ret
; immediate

