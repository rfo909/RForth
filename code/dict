

: Dict
	create
	*Dict @ >R RSwap
		(store current dictionary pointer - includes the newly created word)
; 

: DictEnd
	RSwap
	
	(set address of the new Dict entry)
	*Dict @ 
		RDup R> DE->address !
	
	(change global dictionary to point to omit content added since Dict)
	R> *Dict !
;

