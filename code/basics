(
This file requires >1000 bytes of code segment space to
compile. Must use Nano Every or the 2560.

Once in static (Flash) space, all the code is available
to the atmega328p 
)

: DATA_SEGMENT 0x4000 ;
: *Dict DATA_SEGMENT ;
: *dictHead *Dict @ ;

: constant (value -- )
	create                             (makes a DE_CONSTANT with value 0 - dont need to set DE->type)
	(value) *dictHead 3 + !            (3+ = DE->address)
;

2 constant OP_BVAL
3 constant OP_CVAL
4 constant OP_RET
5 constant OP_JMP
6 constant OP_COND_JMP
7 constant OP_BLOB

0 constant DE_NORMAL
1 constant DE_IMMEDIATE
2 constant DE_CONSTANT

2 constant cell


: 1+ 1 + ;
: cells cell * ;

: over 1 pick ;
: 2dup over over ;


(for these, we must temp-store the top value on the data stack, since these words have return addresses)

: RDup 
	R> 
	0 rpick 
	>R 
;
: RSwap
	R> 
	R> R> swap >R >R 
	>R 
;
: RDrop 
	R> 
	R> drop 
	>R 
;


(dictionary entry field offsets)

: DE->name (dePtr -- fieldPtr) ;
: DE->type (dePtr -- fieldPtr) 2 + ;	(1 byte)
: DE->address (dePtr -- fieldPtr) 3 + ;
: DE->next (dePtr -- fieldPtr) 5 + ;

: variable (--)
	HERE cell allot constant
;


: immediate
	DE_IMMEDIATE *dictHead DE->type c!
;




(execute a dictionary entry)

: DE_execute (DE -- ...)
	dup DE->type c@ DE_CONSTANT == &1 jmp?
	DE->address @ dcall
	ret
	/1
	DE->address @
;

(compile a dictionary entry)

: DE_compile (DE -- )
	dup DE->type c@ DE_CONSTANT == &1 jmp?

		(compile call as two bytes with high bit set)
		DE->address @

		dup 8 >> 0xFF & 0x80 | comp.out
		0xFF & comp.out
		ret
	
	/1 (constant)
		(compile static value)
		OP_CVAL comp.out
		
		DE->address @
		dup 8 >> 0xFF & comp.out
		0xFF & comp.out 
;
	
	
	

(Ex. 145 123 kL  --- results in 145123 as Long value on xStack)
: kL (kval val -- Lval)
	swap >L 1000 >L L* 
	>L L+
;

: cr 0x0A emit ;

: , HERE cell allot ! ;

: c, HERE 1 allot c! ;


48 constant CH_ZERO
49 constant CH_ONE


: .bit (bool --)
	&1 jmp?  
	CH_ZERO emit ret
	/1 CH_ONE emit
;

: .bits (byte --)
	0x80    (byte bit)
	/0
		dup 0 == &1 jmp?    (exit)
		dup (byte bit bit)
		2 pick & .bit (byte bit)
		1 >>
		&0 jmp
	/1
		drop drop
;



34 constant CH_QUOT		(The " character)

(
Create blob (string) of bytes up to the end quote. Only works 
for compile, as it generates code into (net yet allocated) memory
in the code segment. The OP_BLOB executes by reading the length, 
advancing the program pointer past the length byte and the following
bytes, then pushing the address of the length byte on the stack
)
: s" ( -- )
	OP_BLOB comp.out
	
	comp.next >R   (store address of length field)
	0 comp.out    (length field dummy value)
	
	0	(count)
	/0
		key 
		dup 			(count char char)
			CH_QUOT == &2 jmp?   (--- matching quote found)
		(char) comp.out           (count)
		1 +
		&0 jmp
	/2
		drop
		R> 
			c!  (patch the length field)
; immediate


: type (ptr count -- )
	swap			(n ptr)
	0			(n ptr count)
	/0
		dup 3 pick == &1 jmp? (count == n ?)
		dup  (n ptr count count)
			2 pick + c@ emit
		1+
		&0 jmp
	/1
		drop drop drop
;
			
		

: .str (str -- ) dup 1+ swap c@ type ;


: hello cr s" World Hello swap" .str ;

(
Create static data tables in the code segment
----------------------------------------------
See pins code file
)

(put next address of code segment on stack)
: Code[ 
	comp:init 
	code.next 
;

(write byte to code segment)
: c>C (byte)   
	comp.out 
;

(write cell to code segment)
: >C (cell) 
	dup 8 >> 0xFF & c>C
	0xFF & c>C
;

(commit the "compiled" code)
: ]Code 
	comp:done 
;	


: .c? (byte --)  (show printable char, or ignore)
	dup 33 <
	over 126 >
	or &1 jmp?
		emit ret
	/1 drop
;


: mem-dump (address count --)
	swap
	/0
		cr 
		dup .hex s" - " .str
		dup c@ .hex  (print as hex)
		s"  " .str
		dup c@ .u    (print unsigned decimal)
		s"  " .str
		dup c@ .c?   (print char if printable)
		
		1 +  (address update)
		swap 
		1 -  (count update)
		
		(32 emit dup .)
		
		dup 0 == &1 jmp?  (count is 0)
		swap
		&0 jmp
	/1
		drop drop
;


: RegOr (mask addr) 
	swap over  (addr mask addr)
	hw@        (addr mask value)
	|          (addr newValue)
	swap hw!
;

: RegAnd (mask addr) 
	swap over  (addr mask addr)
	hw@        (addr mask value)
	&          (addr newValue)
	swap hw!
;



