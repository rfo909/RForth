: Pin.ddr  (pin) c@ ;
: Pin.port (pin) 1 + c@ ;
: Pin.pin  (pin) 2 + c@ ;
: Pin.mask (pin) 3 + c@ ;


: RegOr (mask addr) 
	swap over  (addr mask addr)
	hw@        (addr mask value)
	|          (addr newValue)
	swap hw!
;

: RegAnd (mask addr) 
	swap over  (addr mask addr)
	hw@        (addr mask value)
	&          (addr newValue)
	swap hw!
;

: Pin:out (pin)
	dup Pin.ddr		(pin reg)
	swap Pin.mask           (reg mask)
	swap RegOr
;

: Pin:in (pin)
	dup Pin.ddr
	swap Pin.mask inv
	swap RegAnd
;


: Pin:0 (pin)
	dup Pin.port swap    (reg pin)
	Pin.mask inv swap RegAnd 
;

: Pin:1 (pin)
	dup Pin.port swap    (reg pin)
	Pin.mask swap RegOr 
;

: Pin:pullup (pin) 
	Pin:1
;

: Pin:pulldown (pin)
	Pin:0
;

(digital write to pin)
: Pin.writeDigital (value pin) 
	swap &1 jmp?
		(low)
		Pin:0 ret
	/1
		(high)
		Pin:1
;

: Pin.readDigital (pin)
	dup Pin.pin hw@   (pin value)
	swap Pin.mask     (value mask)
;

