(UNDER CONSTRUCTION)

: => (dictPointer [name] -- ...) (compile call to word inside dictionary)
	readNextWord              (name of word we look for - stays in system buffer nextWord)
	/0
		dup 0 == &1 jmp?  (end of dictionary linked list)
		dup DE->name @ nextWordEq &2 jmp?  (found it)
		
		cr dup DE->name @ .str
		
		DE->next @                       (follow next pointer)
		&0 jmp
	/1
		cr s" not found" .str
		(drop)
		ret
	/2
		cr s" found it" .str
		DE->address @        	
; immediate 
	

